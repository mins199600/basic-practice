<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.practice.logincrud.HomeMapper">
    <select id="findUserLogin" parameterType="String" resultType="com.practice.logincrud.User">
        SELECT id, email, password
        FROM member
        WHERE email = #{userId}
    </select>

    <insert id="insertMember" parameterType="com.practice.logincrud.User">
        INSERT INTO member(email, password)
        values (#{email}, #{password});
    </insert>

    <select id="countByEmail" parameterType="string" resultType="int">
        SELECT COUNT(*)
        FROM member
        WHERE email = #{email}
    </select>

</mapper>
