<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.practice.logincrud.member.MemberMapper">
    <select id="findUserLogin" parameterType="com.practice.logincrud.member.UserDto">
        SELECT id, email, password
        FROM member
        WHERE email = #{email}
    </select>

    <insert id="insertMember" parameterType="com.practice.logincrud.member.UserDto">
        INSERT INTO member(email, password)
        values (#{email}, #{password});
    </insert>

    <select id="countByEmail" parameterType="string" resultType="int">
        SELECT COUNT(*)
        FROM member
        WHERE email = #{email}
    </select>

    <select id="findUserByEmail" resultType="com.practice.logincrud.member.UserDto">
        SELECT
            id,
            nickname,
            email,
            password
        FROM member
        WHERE email = #{email}
    </select>

    <update id="updateUser">
        UPDATE member
        <set>
            email = #{user.email},
            nickname = #{user.nickname}

            <if test="user.password != null and user.password != ''">
                , password = #{user.password}
            </if>
        </set>
        WHERE email = #{oldEmail}
    </update>

    <delete id="deleteUser">
        DELETE FROM member
        WHERE email = #{email}
    </delete>

</mapper>
