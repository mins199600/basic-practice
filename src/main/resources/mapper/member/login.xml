<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.practice.logincrud.member.MemberMapper">
    <select id="findUserLogin" parameterType="String" resultType="com.practice.logincrud.member.UserDto">
        SELECT id, email, password
        FROM member
        WHERE email = #{email}
    </select>

    <insert id="insertMember" parameterType="com.practice.logincrud.member.UserDto">
        INSERT INTO member(email, password)
        values (#{email}, #{password});
    </insert>

    <select id="countByEmail" parameterType="string" resultType="int">
        SELECT COUNT(*)
        FROM member
        WHERE email = #{email}
    </select>


    <update id="UpdateUser" parameterType="com.practice.logincrud.member.UserDto">
        update member
        set email = #{email},
            password = #{password}
        where email = #{UpdateUser}
    </update>

    <delete id="deleteUser" parameterType="String">
        DELETE FROM member
        WHERE email = #{email}
    </delete>

</mapper>
